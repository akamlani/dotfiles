# Dotfile repository configuration
GIT_USER=akamlani
DOTFILES_REMOTE=dotfiles
VAULTSPACE_ROOT=$(HOME)/Dropbox/dev-vault/workspace

# Use HTTPS so clone works without SSH keys; use git@github.com:$(GIT_USER)/dotfiles.git for SSH
DOTFILES_REPO=https://github.com/$(GIT_USER)/$(DOTFILES_REMOTE).git
DOTFILES_DIR=_shared/$(DOTFILES_REMOTE)
BRANCH=main

# Python deppendencies
PYTHON_VERSION=3.12
ENV_DEP_PATH=environment/dependencies
# package information
PACKAGE_NAME=dotfiles
PACKAGE_INSTALL_NAME=dotfiles-setup
